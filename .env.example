# MusicVision environment configuration
# Copy this file to .env and fill in your values.
# Already-set shell environment variables always take priority over this file.

# ---------------------------------------------------------------------------
# PyTorch CUDA memory management
# ---------------------------------------------------------------------------
# Reduces OOM errors during sustained batch runs by allowing PyTorch to
# reuse fragmented VRAM blocks instead of requiring contiguous allocation.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---------------------------------------------------------------------------
# HuggingFace (required for FLUX.1-dev — gated model)
# ---------------------------------------------------------------------------
# Run `huggingface-cli login` once, OR set this token.
# FLUX.1-schnell and Z-Image are open and do not require a token.
# HUGGINGFACE_TOKEN=hf_...

# ---------------------------------------------------------------------------
# Model weight locations
# ---------------------------------------------------------------------------
# Team members can point these to a shared network drive or local cache.
# All have sensible defaults — only set if you need a custom location.

# HuMo weights (DiT, T5, VAE, Whisper, LoRA)
# Default: ~/.cache/musicvision/weights
# MUSICVISION_WEIGHTS_DIR=/mnt/shared/models/musicvision

# HuggingFace hub cache (FLUX, Z-Image, transformers models)
# Default: ~/.cache/huggingface/hub
# HF_HOME=/mnt/shared/models/huggingface

# HunyuanVideo-Avatar repo and venv
# Default: (must be set in project.yaml or here)
# HVA_REPO_DIR=/mnt/shared/HunyuanVideoAvatar
# HVA_VENV_PYTHON=/mnt/shared/HunyuanVideoAvatar/.venv/bin/python

# SeedVR2 video upscaler repo and venv
# Clone from: git clone https://github.com/ByteDance-Seed/SeedVR.git
# Default: (must be set in project.yaml or here)
# SEEDVR2_REPO_DIR=/mnt/shared/SeedVR
# SEEDVR2_VENV_PYTHON=/mnt/shared/SeedVR/.venv/bin/python

# ---------------------------------------------------------------------------
# LLM Backend
# ---------------------------------------------------------------------------
# "anthropic" (default) — uses the Anthropic API (Claude)
# "openai"              — uses any OpenAI-compatible API, e.g. local vLLM
LLM_BACKEND=anthropic

# ---------------------------------------------------------------------------
# Anthropic backend (LLM_BACKEND=anthropic)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Local vLLM backend (LLM_BACKEND=openai)
# ---------------------------------------------------------------------------
# URL of your vLLM server's OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://192.168.1.100:8000/v1

# API key — any non-empty string works for local servers
# OPENAI_API_KEY=vllm

# Model to use — must match what vLLM was started with.
# Start vLLM with: vllm serve <MODEL_ID> --tensor-parallel-size 2
#
# Tested candidates for RTX 4080 16GB + RTX 5070 12GB (28GB total):
#
#   Candidate 1 — Best quality (~18GB, 4-bit AWQ)
#   OPENAI_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
#
#   Candidate 2 — Fast + capable (~12GB, 4-bit)
#   OPENAI_MODEL=mistralai/Mistral-Small-3.1-24B-Instruct-2503
#
#   Candidate 3 — Fastest (fits in bf16, no quantisation needed)
#   OPENAI_MODEL=Qwen/Qwen2.5-14B-Instruct
#
# OPENAI_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
